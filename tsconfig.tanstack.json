{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "next-vibe/*": ["./src/app/api/[locale]/*"],
      "next-vibe-ui/*": [
        "./src/packages/next-vibe-ui/tanstack/*",
        "./src/packages/next-vibe-ui/web/*"
      ],
      "server-only": ["./src/packages/next-vibe-ui/tanstack/lib/server-only.ts"]
    }
  },
  "include": ["src/app-tanstack/**/*", "src/packages/**/*", "src/app/**/*"]
}
