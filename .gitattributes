# Force LF line endings for all text files on every platform.
# This overrides core.autocrlf so Windows checkouts stay LF — matches the
# Linux dev/prod baseline and prevents "every file changed" diffs after
# editing on Windows.

* text=auto eol=lf

# Images / binaries — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.wav binary
